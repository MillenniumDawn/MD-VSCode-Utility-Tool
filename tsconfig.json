{
	"compilerOptions": {
		"module": "preserve",
		"moduleResolution": "bundler",
		"target": "es2022",
		"outDir": "out",
		"lib": [
			"es2022",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"importHelpers": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		"out",
		"scripts"
	]
}
